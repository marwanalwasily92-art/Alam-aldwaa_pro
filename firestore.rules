rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required) - The user's email address.
    //   - role: string (required) - The user's role (admin, user).
    //   - displayName: string (optional) - The user's display name.
    //
    // Collection: history
    // Document ID: auto-generated
    // Fields:
    //   - user_id: string (required) - The UID of the user who created this record.
    //   - tool_type: string (required) - The type of tool used.
    //   - input_text: string (optional) - The text input provided by the user.
    //   - image_url: string (optional) - The URL of the image uploaded (if any).
    //   - response: string (required) - The AI-generated response.
    //   - created_at: timestamp (required) - The timestamp when the record was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.user_id;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "marwanalwasily96@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || data.displayName is string);
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['user_id', 'tool_type', 'response', 'created_at']) &&
             data.user_id is string &&
             data.tool_type in ['prescription', 'skin', 'interaction', 'consultation'] &&
             data.response is string &&
             data.created_at is timestamp &&
             (!('input_text' in data) || data.input_text is string || data.input_text == null) &&
             (!('image_url' in data) || data.image_url is string || data.image_url == null) &&
             data.response.size() < 50000 &&
             (!('input_text' in data) || data.input_text == null || (data.input_text is string && data.input_text.size() < 10000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      // Allow users to read only their own history items
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
      
      // Allow users to create history items for themselves
      allow create: if isAuthenticated() && 
                      request.resource.data.user_id == request.auth.uid &&
                      isValidHistoryItem(request.resource.data);
      
      // Allow users to delete only their own history items
      allow delete: if isDocOwner() || isAdmin();
      
      // Updates are not allowed for history items (immutable records)
      allow update: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
