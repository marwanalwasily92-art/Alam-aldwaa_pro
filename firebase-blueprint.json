{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage tracking",
      "type": "object",
      "properties": {
        "usage_count": {
          "type": "integer",
          "description": "Number of requests made today"
        },
        "anonymous_limit": {
          "type": "integer",
          "description": "Dynamic limit for anonymous users switching from private"
        },
        "anonymous_limit_set": {
          "type": "boolean",
          "description": "Whether the anonymous limit has been set for today"
        },
        "last_reset_date": {
          "type": "string",
          "format": "date",
          "description": "The date of the last usage reset (YYYY-MM-DD)"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the user account was created"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "User's role in the system"
        },
        "isAnonymous": {
          "type": "boolean",
          "description": "Whether the user is signed in anonymously"
        },
        "is_private": {
          "type": "boolean",
          "description": "Whether the device has used a private key today"
        }
      },
      "required": ["usage_count", "last_reset_date", "created_at", "role", "isAnonymous"]
    },
    "SystemStats": {
      "title": "SystemStats",
      "description": "Global system statistics for dynamic quotas",
      "type": "object",
      "properties": {
        "user_count": {
          "type": "integer",
          "description": "Total number of active users today"
        },
        "last_reset_date": {
          "type": "string",
          "format": "date",
          "description": "The date of the last global reset (YYYY-MM-DD)"
        }
      },
      "required": ["user_count", "last_reset_date"]
    },
    "History": {
      "title": "History",
      "description": "Temporary history record for synchronization",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID for the history item"
        },
        "input_text": {
          "type": "string",
          "description": "The text input provided by the user"
        },
        "response": {
          "type": "string",
          "description": "The AI generated response"
        },
        "user_id": {
          "type": "string",
          "description": "The UID of the user who created this record"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was created"
        },
        "image_path": {
          "type": "string",
          "description": "Path to the uploaded image in Storage"
        }
      },
      "required": ["id", "user_id", "created_at"]
    },
    "AnalysisCache": {
      "title": "AnalysisCache",
      "description": "Smart caching for AI responses to save quota",
      "type": "object",
      "properties": {
        "tool_type": {
          "type": "string",
          "description": "The tool used for analysis"
        },
        "prompt_hash": {
          "type": "string",
          "description": "Hash of the input prompt"
        },
        "response": {
          "type": "string",
          "description": "The cached AI response"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the cache was created"
        }
      },
      "required": ["tool_type", "prompt_hash", "response", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and quota tracking"
    },
    "/system_stats/daily": {
      "schema": "SystemStats",
      "description": "Global daily usage statistics"
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "Temporary history records"
    },
    "/analysis_cache/{cacheId}": {
      "schema": "AnalysisCache",
      "description": "Cached AI responses"
    }
  }
}
